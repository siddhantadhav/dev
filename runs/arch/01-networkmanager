#!/usr/bin/env bash
set -euo pipefail

pacman -Qq iwd            >/dev/null 2>&1 || pkg_install iwd
pacman -Qq networkmanager >/dev/null 2>&1 || pkg_install networkmanager
pkg_install network-manager-applet networkmanager-openvpn

sudo install -d -m 755 /etc/NetworkManager/conf.d
sudo tee /etc/NetworkManager/conf.d/wifi_backend.conf >/dev/null <<'EOF'
[device]
wifi.backend=iwd
EOF

sudo systemctl disable --now wpa_supplicant.service 2>/dev/null || true

sudo systemctl enable --now iwd
sudo systemctl enable NetworkManager
sudo systemctl reset-failed NetworkManager.service 2>/dev/null || true
sudo systemctl restart NetworkManager.service   # single start, loads the openvpn plugin
