#!/usr/bin/env bash
set -e
[[ -z "${1:-}" ]] && { echo "usage: ./switch <personal|work>"; exit 1; }
[[ -d "$(dirname "$0")/runs/profile-$1" ]] || { echo "no such profile: $1"; exit 1; }

mkdir -p ~/.config/dev
echo "export DEV_PROFILE=$1" > ~/.config/dev/env
# only re-run the profile scripts (which re-link the gitconfig); a profile
# switch shouldn't depend on the full OS/package provisioning succeeding.
exec "$(dirname "$0")/run" "profile-$1"
